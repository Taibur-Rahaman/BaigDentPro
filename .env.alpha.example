# Alpha / staging frontend build — copy to .env.alpha in the repo root (gitignored).
# Build with: npm run build:alpha

# If the API is on another origin (split deploy), set the public API base including /api:
# VITE_API_URL=https://api.YOUR_ALPHA_DOMAIN/api
# Same-origin (Express serves dist/): omit VITE_API_URL — the app uses /api

# Supabase → Project Settings → API (anon key is safe in the browser bundle)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=
