# Vite production build — values here are compiled into the browser bundle.
# Copy to .env.production locally or set in CI before `npm run build`.

# Same-origin deploy (Express serves this app + /api): omit — defaults to /api.
# Split API subdomain:
# VITE_API_URL=https://api.yourdomain.com/api

# Supabase (optional) — anon key is safe to embed in the built SPA; never put service_role here.
# VITE_SUPABASE_URL=https://xxxx.supabase.co
# VITE_SUPABASE_ANON_KEY=
