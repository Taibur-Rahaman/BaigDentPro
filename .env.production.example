# Vite production build — copy to `.env.production` or set in CI before `npm run build`.
# Values are compiled into the browser bundle at build time (not read at runtime on static hosts).

# Required for baigdentpro.com → api.baigdentpro.com split deploy:
VITE_API_URL=https://api.baigdentpro.com

# Temporary: log every API URL in the browser console (remove for production if noisy)
VITE_DEBUG_API=1

# Supabase (optional) — anon key is safe to embed in the built SPA; never put service_role here.
# VITE_SUPABASE_URL=https://xxxx.supabase.co
# VITE_SUPABASE_ANON_KEY=

# Stripe (optional) — publishable key only; used on the clinic subscription page for Payment Element.
# VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...
