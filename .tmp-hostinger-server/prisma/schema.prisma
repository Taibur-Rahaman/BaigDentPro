generator client {
  provider = "prisma-client-js"
}

datasource db {
  // For production, ALWAYS point this to a managed PostgreSQL instance
  // via the DATABASE_URL environment variable, e.g.:
  // DATABASE_URL="postgresql://user:password@host:5432/baigdentpro?connection_limit=10&pool_timeout=30"
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============== USER & AUTH ==============

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String
  name          String
  // SQLite connector doesn't support Prisma enums; use string role instead.
  // Allowed values (by convention): SUPER_ADMIN, CLINIC_ADMIN, DOCTOR
  role          String    @default("DOCTOR")
  phone         String?
  clinicName    String?
  clinicAddress String?
  clinicPhone   String?
  clinicEmail   String?
  clinicLogo    String?
  degree        String?
  specialization String?
  licenseNo     String?
  /// When false, login and API access are blocked (clinic admin / super admin controlled).
  isActive      Boolean   @default(true)
  /// Self-service signups start false until SUPER_ADMIN approves. Staff created by admins are true.
  isApproved    Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  patients      Patient[]
  appointments  Appointment[]
  prescriptions Prescription[]
  invoices      Invoice[]
  labOrders     LabOrder[]
  smsLogs       SmsLog[]
  emailLogs     EmailLog[]
  activityLogs  ActivityLog[]

  clinicId      String?
  clinic        Clinic?   @relation(fields: [clinicId], references: [id])
}

model Clinic {
  id        String   @id @default(cuid())
  name      String
  address   String?
  phone     String?
  email     String?
  logo      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users     User[]
}

// ============== PATIENT MANAGEMENT ==============

model Patient {
  id            String    @id @default(cuid())
  regNo         String?
  name          String
  age           Int?
  gender        String?
  phone         String
  phoneType     String?
  email         String?
  address       String?
  bloodGroup    String?
  occupation    String?
  referredBy    String?
  image         String?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  userId        String
  user          User      @relation(fields: [userId], references: [id])

  medicalHistory   MedicalHistory?
  dentalCharts     DentalChart[]
  treatmentPlans   TreatmentPlan[]
  treatmentRecords TreatmentRecord[]
  appointments     Appointment[]
  prescriptions    Prescription[]
  invoices         Invoice[]
  labOrders        LabOrder[]
  consents         PatientConsent[]

  @@index([userId])
  @@index([phone])
  @@index([name])
}

model MedicalHistory {
  id                String   @id @default(cuid())
  patientId         String   @unique
  patient           Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  bloodPressure     Boolean  @default(false)
  heartProblems     Boolean  @default(false)
  diabetes          Boolean  @default(false)
  pepticUlcer       Boolean  @default(false)
  jaundice          Boolean  @default(false)
  asthma            Boolean  @default(false)
  tuberculosis      Boolean  @default(false)
  kidneyDiseases    Boolean  @default(false)
  aids              Boolean  @default(false)
  thyroid           Boolean  @default(false)
  hepatitis         Boolean  @default(false)
  stroke            Boolean  @default(false)
  bleedingDisorder  Boolean  @default(false)
  otherDiseases     String?

  isPregnant        Boolean  @default(false)
  isLactating       Boolean  @default(false)

  allergyPenicillin Boolean  @default(false)
  allergySulphur    Boolean  @default(false)
  allergyAspirin    Boolean  @default(false)
  allergyLocalAnesthesia Boolean @default(false)
  allergyOther      String?

  takingAspirin     Boolean  @default(false)
  takingAntihypertensive Boolean @default(false)
  takingInhaler     Boolean  @default(false)
  takingOther       String?

  habitSmoking      Boolean  @default(false)
  habitBetelLeaf    Boolean  @default(false)
  habitAlcohol      Boolean  @default(false)
  habitOther        String?

  notes             String?
  updatedAt         DateTime @updatedAt
}

// ============== DENTAL CHART ==============

model DentalChart {
  id            String   @id @default(cuid())
  patientId     String
  patient       Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  
  toothNumber   Int
  condition     String
  notes         String?
  treatment     String?
  treatmentDate DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([patientId, toothNumber])
  @@index([patientId])
}

// ============== TREATMENT PLANS & RECORDS ==============

model TreatmentPlan {
  id            String   @id @default(cuid())
  patientId     String
  patient       Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  
  toothNumber   String?
  diagnosis     String
  procedure     String
  cost          Float    @default(0)
  cc            String?
  cf            String?
  investigation String?
  status        String   @default("NOT_STARTED")
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([patientId])
}

model TreatmentRecord {
  id             String   @id @default(cuid())
  patientId      String
  patient        Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  
  date           DateTime @default(now())
  treatmentDone  String
  toothNumber    String?
  cost           Float    @default(0)
  paid           Float    @default(0)
  due            Float    @default(0)
  notes          String?
  doctorSignature String?
  createdAt      DateTime @default(now())

  @@index([patientId])
}

// ============== APPOINTMENTS ==============

model Appointment {
  id            String   @id @default(cuid())
  patientId     String
  patient       Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  
  date          DateTime
  time          String
  duration      Int      @default(30)
  type          String?
  status        String   @default("SCHEDULED")
  notes         String?
  reminderSent  Boolean  @default(false)
  reminderSentAt DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([patientId])
  @@index([userId])
  @@index([date])
}

// ============== PRESCRIPTIONS ==============

model Prescription {
  id            String   @id @default(cuid())
  patientId     String
  patient       Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  
  date          DateTime @default(now())
  diagnosis     String?
  chiefComplaint String?
  examination   String?
  investigation String?
  advice        String?
  followUpDate  DateTime?
  
  vitals        String?
  items         PrescriptionItem[]
  
  pdfUrl        String?
  sentViaWhatsapp Boolean @default(false)
  sentViaEmail  Boolean  @default(false)
  sentViaSms    Boolean  @default(false)
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([patientId])
  @@index([userId])
}

model PrescriptionItem {
  id              String   @id @default(cuid())
  prescriptionId  String
  prescription    Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)
  
  drugName        String
  genericName     String?
  dosage          String
  frequency       String
  duration        String
  beforeFood      Boolean  @default(false)
  afterFood       Boolean  @default(true)
  instructions    String?

  @@index([prescriptionId])
}

// ============== BILLING & INVOICES ==============

model Invoice {
  id            String   @id @default(cuid())
  invoiceNo     String   @unique
  patientId     String
  patient       Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  
  date          DateTime @default(now())
  dueDate       DateTime?
  
  subtotal      Float    @default(0)
  discount      Float    @default(0)
  tax           Float    @default(0)
  total         Float    @default(0)
  paid          Float    @default(0)
  due           Float    @default(0)
  
  status        String   @default("PENDING")
  notes         String?
  
  pdfUrl        String?
  sentViaWhatsapp Boolean @default(false)
  sentViaEmail  Boolean  @default(false)
  
  items         InvoiceItem[]
  payments      Payment[]
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([patientId])
  @@index([userId])
}

model InvoiceItem {
  id          String   @id @default(cuid())
  invoiceId   String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  
  description String
  quantity    Int      @default(1)
  unitPrice   Float    @default(0)
  total       Float    @default(0)
  
  @@index([invoiceId])
}

model Payment {
  id          String   @id @default(cuid())
  invoiceId   String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  
  amount      Float    @default(0)
  method      String   @default("CASH")
  reference   String?
  date        DateTime @default(now())
  notes       String?

  @@index([invoiceId])
}

// ============== LAB TRACKING ==============

model LabOrder {
  id            String   @id @default(cuid())
  patientId     String
  patient       Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  
  labName       String?
  orderDate     DateTime @default(now())
  expectedDate  DateTime?
  deliveryDate  DateTime?
  
  workType      String
  description   String
  toothNumber   String?
  shade         String?
  
  status        String   @default("PENDING")
  cost          Float?
  notes         String?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([patientId])
  @@index([userId])
}

// ============== DENTAL SHOP (E-COMMERCE) ==============

model Product {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique
  description   String?
  shortDesc     String?
  price         Float    @default(0)
  comparePrice  Float?
  cost          Float?
  sku           String?
  barcode       String?
  
  category      String
  images        String?
  
  stock         Int      @default(0)
  lowStockAlert Int      @default(5)
  trackInventory Boolean @default(true)
  
  isActive      Boolean  @default(true)
  isFeatured    Boolean  @default(false)
  
  weight        Float?
  dimensions    String?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  orderItems    OrderItem[]
  cartItems     CartItem[]

  @@index([category])
  @@index([isActive])
}

model Cart {
  id            String   @id @default(cuid())
  sessionId     String   @unique
  items         CartItem[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model CartItem {
  id            String   @id @default(cuid())
  cartId        String
  cart          Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId     String
  product       Product  @relation(fields: [productId], references: [id])
  quantity      Int      @default(1)
  
  @@unique([cartId, productId])
  @@index([cartId])
}

model Order {
  id              String   @id @default(cuid())
  orderNo         String   @unique
  
  customerName    String
  customerEmail   String?
  customerPhone   String
  
  shippingAddress String
  shippingCity    String
  shippingState   String?
  shippingZip     String?
  shippingCountry String   @default("Bangladesh")
  
  subtotal        Float    @default(0)
  shipping        Float    @default(0)
  discount        Float    @default(0)
  total           Float    @default(0)
  
  status          String   @default("PENDING")
  paymentMethod   String   @default("COD")
  paymentStatus   String   @default("PENDING")
  
  notes           String?
  trackingNumber  String?
  
  items           OrderItem[]
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([customerPhone])
  @@index([status])
}

model OrderItem {
  id          String   @id @default(cuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  
  name        String
  price       Float    @default(0)
  quantity    Int
  total       Float    @default(0)

  @@index([orderId])
}

// ============== COMMUNICATION LOGS ==============

model SmsLog {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  
  phone       String
  message     String
  type        String
  status      String
  twilioSid   String?
  error       String?
  sentAt      DateTime @default(now())

  @@index([userId])
}

model EmailLog {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  
  to          String
  subject     String
  body        String?
  type        String
  status      String
  error       String?
  sentAt      DateTime @default(now())

  @@index([userId])
}

// ============== PATIENT CONSENT ==============

model PatientConsent {
  id            String   @id @default(cuid())
  patientId     String
  patient       Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  
  consentType   String
  consentText   String
  signatureName String
  signatureDate DateTime
  agreed        Boolean  @default(false)
  
  createdAt     DateTime @default(now())

  @@index([patientId])
}

// ============== ACTIVITY LOG (for role-based access & super admin) ==============

model ActivityLog {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action     String   // e.g. LOGIN, CREATE_PATIENT, UPDATE_PRESCRIPTION
  entity     String?  // e.g. PATIENT, APPOINTMENT, INVOICE
  entityId   String?
  details    String?  // JSON or short description
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([entity])
  @@index([createdAt])
}

model TestTable {
  id   Int    @id @default(autoincrement())
  name String

  @@map("test_table")
}
