{
  "name": "baigdentpro",
  "version": "0.1.0-beta.0",
  "private": true,
  "workspaces": [
    "server"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "concurrently \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "vite",
    "dev:server": "cd server && npm run dev",
    "build": "vite build",
    "build:server": "cd server && npm run build",
    "build:production": "npm run build && npm run build:server",
    "build:alpha": "vite build --mode alpha",
    "build:alpha:full": "npm run build:alpha && npm run build:server",
    "build:hostinger-static": "vite build",
    "start:production": "NODE_ENV=production npm run start -w server",
    "preview": "vite preview",
    "install:all": "npm i && cd server && npm i",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:push": "cd server && npm run db:push",
    "db:generate": "cd server && npm run db:generate",
    "db:seed": "cd server && npm run db:seed",
    "db:setup": "npm run db:up && cd server && npx prisma db push && npm run db:seed",
    "db:setup:doctor": "npm run db:up && cd server && npx prisma migrate deploy && npm run db:seed",
    "db:push:alpha": "cd server && npx prisma db push",
    "db:migrate:deploy": "cd server && npx prisma migrate deploy",
    "db:seed:alpha": "cd server && npm run db:seed",
    "typecheck": "tsc --noEmit && cd server && tsc --noEmit",
    "smoke:api": "bash scripts/smoke-api.sh",
    "ops:verify": "bash scripts/ops-verify.sh",
    "lint": "eslint src server/src"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.101.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^20.16.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.3",
    "@vitejs/plugin-react-swc": "^3.7.0",
    "concurrently": "^8.2.2",
    "eslint": "^9.6.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^17.5.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.58.1",
    "vite": "^6.0.0"
  }
}
