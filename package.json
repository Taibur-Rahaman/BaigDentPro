{
  "name": "baigdentpro",
  "version": "0.1.0-beta.0",
  "private": true,
  "workspaces": [
    "server"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "concurrently \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "vite",
    "dev:server": "cd server && npm run dev",
    "build": "vite build",
    "build:server": "cd server && npm run build",
    "build:production": "npm run build && npm run build:server",
    "start:production": "NODE_ENV=production npm run start -w server",
    "preview": "vite preview",
    "install:all": "npm i && cd server && npm i",
    "db:push": "cd server && npm run db:push",
    "db:generate": "cd server && npm run db:generate",
    "db:seed": "cd server && npm run db:seed",
    "typecheck": "tsc --noEmit && cd server && tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx && cd server && eslint src --ext .ts"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.16.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.3",
    "@vitejs/plugin-react-swc": "^3.7.0",
    "concurrently": "^8.2.2",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "eslint": "^9.6.1",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.9"
  }
}
