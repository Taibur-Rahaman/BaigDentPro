# BaigDentPro — NGINX site (same-origin SPA + /api reverse proxy)
#
# Copy to e.g. /etc/nginx/sites-available/baigdentpro.conf
# Symlink: ln -s /etc/nginx/sites-available/baigdentpro.conf /etc/nginx/sites-enabled/
#
# Replace:
#   YOUR_DOMAIN      — public hostname (e.g. app.baigdentpro.com)
#   FRONTEND_ROOT      — absolute path to Vite output (repo/dist)
#
# TLS: see docs/deployment/HOSTINGER_VPS.md (certbot).

upstream baigdentpro_api {
    server 127.0.0.1:5000;
    keepalive 32;
}

server {
    listen 80;
    listen [::]:80;
    server_name YOUR_DOMAIN;

    # After certbot, certbot will add SSL server blocks; keep this file as HTTP→HTTPS redirect if desired.

    root FRONTEND_ROOT;
    index index.html;

    gzip on;
    gzip_min_length 256;
    gzip_types text/plain text/css application/javascript application/json image/svg+xml;
    gzip_vary on;

    # Static assets — long cache (hashed filenames from Vite)
    location /assets/ {
        try_files $uri =404;
        add_header Cache-Control "public, max-age=31536000, immutable";
    }

    location = /favicon.ico {
        try_files $uri =404;
        add_header Cache-Control "public, max-age=86400";
    }

    # API → Node (Express keeps full /api prefix — do not strip)
    location /api/ {
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Connection "";
        proxy_pass http://baigdentpro_api;
        proxy_read_timeout 120s;
        proxy_connect_timeout 30s;
    }

    # SPA — fallback to index.html (React Router)
    location / {
        try_files $uri $uri/ /index.html;
        add_header Cache-Control "no-store, no-cache, must-revalidate";
    }

    location = /index.html {
        add_header Cache-Control "no-store, no-cache, must-revalidate";
    }
}
