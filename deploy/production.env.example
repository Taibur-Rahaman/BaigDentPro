# =============================================================================
# BaigDentPro — production deployment environment (Hostinger VPS / same-origin NGINX)
# =============================================================================
# DO NOT commit real secrets. Copy snippets into:
#   server/.env          — runtime for Node (Prisma + JWT + DB)
#   .env.production      — used only when running `npm run build` (Vite embeds public vars)
#
# Same-origin setup: browser loads https://YOUR_DOMAIN and calls https://YOUR_DOMAIN/api/...
# NGINX proxies /api → http://127.0.0.1:5000 (PM2). Node binds loopback only (see ecosystem.config.cjs HOST).
# =============================================================================

# -----------------------------------------------------------------------------
# Backend — file: server/.env (never expose publicly)
# -----------------------------------------------------------------------------
NODE_ENV=production

# PostgreSQL (required). Use managed Postgres or Docker on the VPS — never commit passwords.
DATABASE_URL=postgresql://USER:PASSWORD@127.0.0.1:5432/baigdentpro?schema=public

# Prisma migrate deploy uses DATABASE_URL. For some hosts you may also need:
# DIRECT_URL=postgresql://USER:PASSWORD@127.0.0.1:5432/baigdentpro?schema=public

# JWT signing (required in production — min length enforced by envSecurity when configured)
JWT_SECRET=replace-with-long-random-string

# API port — must match ecosystem.config.cjs and NGINX upstream
PORT=5000

# Bind loopback only so only NGINX hits Node on the VPS
HOST=127.0.0.1

# CORS + redirects (required in production): comma-separated origins for your SPA
# Must include the exact browser origin (scheme + host, no path), e.g.:
FRONTEND_URL=https://YOUR_DOMAIN

# Optional: Twilio, SMTP, Supabase — see server/.env.example

# -----------------------------------------------------------------------------
# Frontend build — file: .env.production at repo root (only for `npm run build`)
# -----------------------------------------------------------------------------
# The SPA validates full HTTPS URL ending in /api (see src/config/api.ts).
# Same-origin deployment example:
VITE_API_BASE_URL=https://YOUR_DOMAIN/api

# Optional split-domain deploy (API subdomain):
# VITE_API_BASE_URL=https://api.YOUR_DOMAIN/api

# Disable noisy logs in real prod builds:
# VITE_DEBUG_API=0

# -----------------------------------------------------------------------------
# Notes
# -----------------------------------------------------------------------------
# - Run migrations with: cd server && npx prisma migrate deploy (deploy.sh does this).
# - Never use prisma migrate dev or db push against production unless you intend to.
# - PM2: npm i -g pm2 && pm2 startup && ./deploy.sh
