{
  "name": "baigdentpro-server",
  "version": "1.0.0",
  "description": "BaigDentPro Dental Management System Backend",
  "type": "module",
  "main": "dist/index.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "prisma generate && npx tsc",
    "start": "node dist/index.js",
    "db:push": "prisma db push",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "db:seed": "tsx src/seed.ts",
    "db:seed:demo-users": "tsx prisma/seedDemoUsers.ts",
    "db:verify-superadmin": "tsx scripts/verify-superadmin.ts",
    "db:seed:demo": "SEED_MODE=demo tsx src/seed.ts",
    "db:test": "tsx scripts/test-db.ts",
    "db:drift": "tsx scripts/db-drift-check.ts",
    "migrate:safe": "tsx scripts/db-drift-check.ts --fail-on-drift && prisma migrate status && prisma migrate deploy",
    "db:setup:doctor": "prisma migrate deploy && npm run db:seed"
  },
  "dependencies": {
    "@prisma/client": "^5.10.0",
    "@supabase/supabase-js": "^2.101.1",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "express-rate-limit": "^8.5.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^8.0.5",
    "pdfkit": "^0.15.0",
    "twilio": "^5.0.0",
    "uuid": "^9.0.1",
    "zod": "^3.22.4",
    "prisma": "^5.10.0",
    "typescript": "^5.3.3",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.11.19",
    "@types/nodemailer": "^6.4.14",
    "@types/pdfkit": "^0.17.5",
    "@types/uuid": "^9.0.8"
  },
  "devDependencies": {
    "tsx": "^4.7.1"
  }
}
