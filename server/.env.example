# Copy to server/.env — never commit real values.
# Hosted alpha with Supabase: use .env.alpha.example as the checklist template.

# Production: set NODE_ENV=production on the host (or use start:production from repo root).
NODE_ENV=development

# Comma-separated browser origins allowed to call the API (required when NODE_ENV=production)
# Example: https://app.yourdomain.com,https://www.yourdomain.com
# FRONTEND_URL=

# Database — Supabase Postgres (recommended)
# Replace with real Supabase credentials from Dashboard → Project Settings → Database → Connection string (URI).
# Example placeholder (password + PROJECT_ID must come from your project):
# DATABASE_URL="postgresql://postgres:<PASSWORD>@db.<PROJECT_ID>.supabase.co:6543/postgres?sslmode=require"
#
# Transaction pool (6543) for the app; session pool (5432) for Prisma Migrate — copy both from Dashboard Connect (host may be aws-0- or aws-1-).
# DIRECT_URL="postgresql://postgres.<PROJECT_ID>:<PASSWORD>@aws-0-<REGION>.pooler.supabase.com:5432/postgres?sslmode=require"
#
# For Session/Transaction pooler, Supabase often shows host like aws-0-<region>.pooler.supabase.com:6543 — use that URI as-is.
# Local Docker Postgres only: set ALLOW_LOCALHOST_DB=1 and point DATABASE_URL at localhost (never use localhost in production).

# JWT (required for auth)
JWT_SECRET=your-secret-key-change-in-production
# Access token TTL (use 1h–2h; refresh tokens extend active sessions)
JWT_EXPIRES_IN=2h
# Refresh tokens (hashed in DB); optional override (default 30)
# JWT_REFRESH_EXPIRES_DAYS=30

# Supabase Storage bucket for POST /api/upload (create as public in Supabase if you need public URLs)
# SUPABASE_STORAGE_BUCKET=saas-uploads

# Supabase Auth (optional — enables Supabase sign-in, forgot password, recovery, and automatic Auth user sync)
# Dashboard: https://supabase.com — Project Settings → API (URL + service_role secret, server only).
# Client build needs VITE_SUPABASE_URL + VITE_SUPABASE_ANON_KEY (see repo root .env.production.example).
# Invite emails use FRONTEND_URL (first origin) as redirect — add the same URL in Supabase Auth → URL Configuration.
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_KEY=                        # legacy alias (deprecated); prefer SUPABASE_SERVICE_ROLE_KEY

# Server port (optional)
PORT=5000

# SaaS subscription WhatsApp (manual settlement) — digits only, country code included (no +).
# Used by POST /api/payment/manual/initiate to build https://wa.me/...
# ADMIN_WHATSAPP_NUMBER=8801712345678

# Optional: shown in GET /api/health as "version" (defaults to root package.json version)
# APP_VERSION=0.1.0-beta.0
# APP_VERSION=abc1234   # e.g. git short SHA from your deploy pipeline

# Rate limits (optional) — requests per window; tighten AUTH in production if you see abuse
# AUTH: per IP per 15 minutes on /api/auth/* (default 60)
# API: per IP per minute on /api/* (default 300)
# AUTH_RATE_LIMIT_MAX=40
# API_RATE_LIMIT_MAX=200

# Twilio SMS (optional - for appointment reminders)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=

# Email SMTP (optional - for sending prescriptions/invoices)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=

# Optional: seed creates/updates an approved clinic admin (npm run db:seed)
# OMIX_SERVICE_USER_EMAIL=
# OMIX_SERVICE_USER_PASSWORD=

# Demo users seed/reset safety gate (required for `tsx prisma/seedDemoUsers.ts` and super-admin demo reset route)
# ENABLE_DEMO_USERS=true

# Platform WhatsApp (digits only, no +) — used for manual SaaS subscription checkout (`wa.me` deep links)
# ADMIN_WHATSAPP_NUMBER=8801712345678

# WhatsApp Business API (optional — outbound API sends; separate from manual checkout above)
# WHATSAPP_API_URL=
# WHATSAPP_API_TOKEN=
