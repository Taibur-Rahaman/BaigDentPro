# Copy to server/.env — never commit real values.

# Production: set NODE_ENV=production on the host (or use start:production from repo root).
NODE_ENV=development

# Comma-separated browser origins allowed to call the API (required when NODE_ENV=production)
# Example: https://app.yourdomain.com,https://www.yourdomain.com
# FRONTEND_URL=

# Database
# IMPORTANT:
# - For development you MAY use SQLite by setting:
#   DATABASE_URL="file:./dev.db"
# - For any professional / production deployment you MUST use a managed PostgreSQL instance with TLS:
#   DATABASE_URL="postgresql://user:password@host:5432/baigdentpro?sslmode=require&connection_limit=10&pool_timeout=30"
# - Never commit real credentials. Restrict DB firewall to your app servers only.

# JWT (required for auth)
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# Server port (optional)
PORT=3001

# Twilio SMS (optional - for appointment reminders)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=

# Email SMTP (optional - for sending prescriptions/invoices)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=

# WhatsApp Business API (optional)
# WHATSAPP_API_URL=
# WHATSAPP_API_TOKEN=
