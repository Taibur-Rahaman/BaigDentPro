# Database (SQLite by default - no setup required)
# For PostgreSQL instead, change prisma/schema.prisma provider and set:
# DATABASE_URL="postgresql://user:password@localhost:5432/baigdentpro"

# JWT (required for auth)
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# Server port (optional)
PORT=3001

# Twilio SMS (optional - for appointment reminders)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=

# Email SMTP (optional - for sending prescriptions/invoices)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=

# WhatsApp Business API (optional)
# WHATSAPP_API_URL=
# WHATSAPP_API_TOKEN=
