generator client {
  provider = "prisma-client-js"
}

datasource db {
  // For production, ALWAYS point this to a managed PostgreSQL instance
  // via the DATABASE_URL environment variable, e.g.:
  // DATABASE_URL="postgresql://user:password@host:5432/baigdentpro?connection_limit=10&pool_timeout=30"
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // Session/direct path for Prisma Migrate (avoid transaction pooler 6543 for migrations).
  directUrl = env("DIRECT_URL")
}

// ============== USER & AUTH ==============

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  password      String
  name          String
  // SQLite connector doesn't support Prisma enums; use string role instead.
  // Canonical: SUPER_ADMIN | CLINIC_ADMIN | DOCTOR | STORE_MANAGER (+ legacy CLINIC_OWNER, RECEPTIONIST,
  // LAB_TECH, DENTAL_ASSISTANT, TENANT=PaaS-shop-only alias, PENDING_APPROVAL onboarding).
  role          String    @default("DOCTOR")
  phone         String?
  clinicName    String?
  clinicAddress String?
  clinicPhone   String?
  clinicEmail   String?
  clinicLogo    String?
  /// Honorific / prefix only (e.g. "Dr.", "Prof.") — not duplicated in `name`.
  title         String?
  degree        String?
  specialization String?
  licenseNo     String?
  /// Super Admin–verified professional credentials (title/degree/specialization locked for self-service edits).
  professionalVerified   Boolean   @default(false)
  professionalVerifiedAt DateTime?
  /// When false, login and API access are blocked (clinic admin / super admin controlled).
  isActive      Boolean   @default(true)
  /// Self-service signups start false until SUPER_ADMIN approves. Staff created by admins are true.
  isApproved    Boolean   @default(true)
  /// Access lifecycle: PENDING (awaiting SuperAdmin assignment), ACTIVE (full access), SUSPENDED (blocked).
  accountStatus String    @default("PENDING")
  /// Bumped to invalidate issued JWTs (password change, logout-all, role change, etc.).
  sessionVersion Int      @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  patients      Patient[]
  appointments  Appointment[]
  prescriptions Prescription[]
  invoices      Invoice[]
  labOrders     LabOrder[]
  smsLogs       SmsLog[]
  emailLogs     EmailLog[]
  activityLogs  ActivityLog[]

  clinicId      String
  clinic        Clinic    @relation(fields: [clinicId], references: [id])
  branchId      String?
  branch        Branch?   @relation(fields: [branchId], references: [id])

  ownedClinics  Clinic[]  @relation("ClinicOwner")
  deviceSessions DeviceSession[]

  /// One-to-one SaaS profile (`Profile` / `profiles`).
  profile       Profile?
  refreshTokens RefreshToken[]

  /// Branding / header JSON for the legacy practice doctor panel (`/practice`).
  doctorPanelSettings DoctorPanelSettings?

  auditLogs AuditLog[]
  fraudAlerts FraudAlert[]
  impersonationSessionsAsActor ImpersonationSession[] @relation("ImpersonationActor")
  verifiedInvoicePayments Payment[] @relation("InvoicePaymentVerifiedBy")
  subscriptionPaymentsCreated SubscriptionPayment[] @relation("SubscriptionPaymentRequester")
}

/// Security / compliance audit trail (structured metadata).
model AuditLog {
  id             String   @id @default(uuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  clinicId       String?
  clinic         Clinic?  @relation(fields: [clinicId], references: [id], onDelete: SetNull)
  action         String
  entityId       String?
  entityType     String?
  metadata       Json?
  ipAddress      String?
  userAgent      String?
  beforeSnapshot Json?
  afterSnapshot  Json?
  createdAt      DateTime @default(now())

  @@index([userId])
  @@index([clinicId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

model Clinic {
  id        String   @id @default(cuid())
  name      String
  plan      String   @default("FREE")
  /// Commercial tier for DPMS feature matrix: STARTER | GROWTH | ENTERPRISE
  planTier  String   @default("STARTER")
  /// Demo/sandbox clinics — isolated datasets; SuperAdmin may reset without touching production tenants.
  isDemo    Boolean  @default(false)
  isActive  Boolean  @default(true)
  ownerId   String?
  address   String?
  phone     String?
  email     String?
  logo      String?
  settings  Json     @default("{}")
  /// IANA zone name (e.g. Asia/Dhaka); optional display/scheduling hint.
  timezone  String?
  /// BD = CASH + bKash + Nagad + Stripe. INTERNATIONAL = CASH + Stripe only.
  region    String   @default("BD")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner         User?    @relation("ClinicOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  users         User[]
  patients      Patient[]
  branches      Branch[]
  deviceSessions DeviceSession[]
  products      Product[]
  orders        Order[]
  profits       Profit[]
  subscription  Subscription?
  invites       Invite[]
  subscriptionPayments SubscriptionPayment[]
  activityLogs  ActivityLog[] @relation("ClinicActivityLogs")
  auditLogs     AuditLog[]
  impersonationSessions ImpersonationSession[]
  fraudAlerts   FraudAlert[]
  appointments  Appointment[]
  invoices      Invoice[]
  patientPortalOtps PatientPortalOtp[]
  appointmentWaitlistEntries AppointmentWaitlistEntry[]
  featureFlagRows           ClinicFeatureFlag[]
  capabilityOverrides       ClinicCapabilityOverride[]
}

/// Per-clinic feature overrides (enterprise toggles). Server merges with plan tier defaults + subscription JSON.
model ClinicFeatureFlag {
  id         String   @id @default(cuid())
  clinicId   String
  clinic     Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  featureKey String
  enabled    Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([clinicId, featureKey])
  @@index([clinicId])
  @@map("clinic_feature_flags")
}

/// SuperAdmin-controlled overlay on effective capabilities (`grant`=true adds; `grant`=false revokes).
model ClinicCapabilityOverride {
  id             String   @id @default(cuid())
  clinicId       String
  clinic         Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  capabilityKey  String
  /// When true: force-include capability (within taxonomy). When false: force-remove even if role+plan allow.
  grant          Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([clinicId, capabilityKey])
  @@index([clinicId])
  @@map("clinic_capability_overrides")
}

model Plan {
  id          String         @id @default(uuid())
  name        String         @unique
  price       Int
  deviceLimit Int
  features    Json
  createdAt   DateTime       @default(now())

  subscriptions Subscription[]

  @@map("plans")
}

model Branch {
  id        String   @id @default(uuid())
  clinicId  String
  name      String
  address   String?

  clinic  Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  users   User[]
  invites Invite[]

  @@index([clinicId])
  @@map("branches")
}

model DeviceSession {
  id        String   @id @default(uuid())
  userId    String
  clinicId  String
  deviceId  String
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@unique([userId, clinicId, deviceId])
  @@index([clinicId])
  @@map("device_sessions")
}

model Subscription {
  id        String    @id @default(uuid())
  clinicId  String    @unique
  clinic    Clinic    @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  /// Legacy string tier (FREE, PRO, …). When `planId` is set, keep this in sync with `planRef.name` for JWTs and older clients.
  plan      String    @default("FREE")
  planId    String?
  planRef   Plan?     @relation(fields: [planId], references: [id], onDelete: SetNull)
  status    String    @default("ACTIVE")
  startDate DateTime?
  endDate   DateTime?
  autoRenew Boolean   @default(true)
  /// Per-tenant feature overrides (e.g. `{ "orders.export": true }`). Server enforces with `featureFlags` + `requireFeature` / `requirePlanFeature`.
  features  Json      @default("{}")
  expiresAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([planId])
  @@map("subscriptions")
}

/// SaaS subscription checkout — **manual WhatsApp settlement only** (see `/config/payment.ts` policy).
model SubscriptionPayment {
  id          String   @id @default(uuid())
  clinicId    String
  /// User who initiated the payment request (clinic admin).
  userId      String?
  user        User?    @relation("SubscriptionPaymentRequester", fields: [userId], references: [id], onDelete: SetNull)
  amount      Int
  method      String
  /// PENDING | CONTACTED | PAID | REJECTED (legacy rows may still read SUCCESS from older Stripe flow).
  status      String
  externalRef String?
  planCode    String?
  /// Human-readable plan title for WhatsApp template (e.g. "PREMIUM").
  planName    String?
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@index([clinicId])
  @@index([status])
  @@index([userId])
  @@map("subscription_payments")
}

model PaymentEventLog {
  id                    String   @id @default(uuid())
  clinicId              String?
  subscriptionPaymentId String?
  event                 String
  payload               Json?
  verified              Boolean  @default(false)
  ipAddress             String?
  createdAt             DateTime @default(now())

  @@index([clinicId])
  @@index([subscriptionPaymentId])
  @@index([createdAt])
  @@map("payment_event_logs")
}

model ImpersonationSession {
  id             String    @id @default(uuid())
  jti            String    @unique
  actorUserId    String
  actor          User      @relation("ImpersonationActor", fields: [actorUserId], references: [id], onDelete: Cascade)
  targetClinicId String
  targetClinic   Clinic    @relation(fields: [targetClinicId], references: [id], onDelete: Cascade)
  expiresAt      DateTime
  revokedAt      DateTime?
  createdAt      DateTime  @default(now())

  @@index([actorUserId])
  @@index([targetClinicId])
  @@map("impersonation_sessions")
}

model FraudAlert {
  id        String   @id @default(uuid())
  clinicId  String?
  clinic    Clinic?  @relation(fields: [clinicId], references: [id], onDelete: SetNull)
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  rule      String
  riskScore Int
  riskLevel String
  /// True when raised by automated rule engine (vs manual review).
  autoFlag  Boolean  @default(false)
  details   Json?
  createdAt DateTime @default(now())

  @@index([clinicId])
  @@index([userId])
  @@index([createdAt])
  @@map("fraud_alerts")
}

/// Email-based staff onboarding for a clinic.
model Invite {
  id        String   @id @default(uuid())
  email     String
  /// DOCTOR, RECEPTIONIST, or ADMIN (accepted as CLINIC_ADMIN on the User row).
  role      String
  clinicId  String
  branchId  String?
  token     String   @unique
  expiresAt DateTime
  accepted  Boolean  @default(false)

  clinic Clinic  @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  branch Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)

  @@index([clinicId])
  @@index([email])
  @@map("invites")
}

model RefreshToken {
  id         String    @id @default(uuid())
  tokenHash  String    @unique
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId])
  @@map("refresh_tokens")
}

// ============== PATIENT MANAGEMENT ==============

model Patient {
  id            String    @id @default(cuid())
  regNo         String?
  name          String
  age           Int?
  gender        String?
  phone         String
  phoneType     String?
  email         String?
  address       String?
  bloodGroup    String?
  occupation    String?
  referredBy    String?
  image         String?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  clinicId      String
  clinic        Clinic    @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  userId        String
  user          User      @relation(fields: [userId], references: [id])

  medicalHistory   MedicalHistory?
  dentalCharts     DentalChart[]
  treatmentPlans   TreatmentPlan[]
  treatmentRecords TreatmentRecord[]
  appointments     Appointment[]
  prescriptions    Prescription[]
  invoices         Invoice[]
  labOrders        LabOrder[]
  consents         PatientConsent[]
  portalOtps       PatientPortalOtp[]
  portalRefreshTokens PatientPortalRefreshToken[]
  appointmentWaitlistEntries AppointmentWaitlistEntry[]

  @@index([userId])
  @@index([clinicId])
  @@index([phone])
  @@index([name])
  @@unique([id, clinicId], name: "patient_id_clinic_unique")
}

model PatientPortalOtp {
  id        String   @id @default(cuid())
  patientId String
  clinicId  String
  codeHash  String
  expiresAt DateTime
  createdAt DateTime @default(now())

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  clinic  Clinic  @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@index([patientId, clinicId])
  @@index([expiresAt])
  @@map("patient_portal_otps")
}

model PatientPortalRefreshToken {
  id        String    @id @default(uuid())
  tokenHash String    @unique
  patientId String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@map("patient_portal_refresh_tokens")
}

model MedicalHistory {
  id                String   @id @default(cuid())
  patientId         String   @unique
  patient           Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  bloodPressure     Boolean  @default(false)
  heartProblems     Boolean  @default(false)
  diabetes          Boolean  @default(false)
  pepticUlcer       Boolean  @default(false)
  jaundice          Boolean  @default(false)
  asthma            Boolean  @default(false)
  tuberculosis      Boolean  @default(false)
  kidneyDiseases    Boolean  @default(false)
  aids              Boolean  @default(false)
  thyroid           Boolean  @default(false)
  hepatitis         Boolean  @default(false)
  stroke            Boolean  @default(false)
  bleedingDisorder  Boolean  @default(false)
  otherDiseases     String?

  isPregnant        Boolean  @default(false)
  isLactating       Boolean  @default(false)

  allergyPenicillin Boolean  @default(false)
  allergySulphur    Boolean  @default(false)
  allergyAspirin    Boolean  @default(false)
  allergyLocalAnesthesia Boolean @default(false)
  allergyOther      String?

  takingAspirin     Boolean  @default(false)
  takingAntihypertensive Boolean @default(false)
  takingInhaler     Boolean  @default(false)
  takingOther       String?

  habitSmoking      Boolean  @default(false)
  habitBetelLeaf    Boolean  @default(false)
  habitAlcohol      Boolean  @default(false)
  habitOther        String?

  notes             String?
  updatedAt         DateTime @updatedAt
}

// ============== DENTAL CHART ==============

model DentalChart {
  id            String   @id @default(cuid())
  patientId     String
  patient       Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  
  toothNumber   Int
  condition     String
  /// Per-surface state keyed by M | D | O | B | L (JSON object).
  surfaces      Json      @default("{}")
  notes         String?
  treatment     String?
  treatmentDate DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([patientId, toothNumber])
  @@index([patientId])
}

// ============== TREATMENT PLANS & RECORDS ==============

model TreatmentPlan {
  id            String   @id @default(cuid())
  patientId     String
  patient       Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  
  toothNumber   String?
  diagnosis     String
  procedure     String
  cost          Float    @default(0)
  cc            String?
  cf            String?
  investigation String?
  status        String   @default("NOT_STARTED")
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([patientId])
}

model TreatmentRecord {
  id             String   @id @default(cuid())
  patientId      String
  patient        Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  
  date           DateTime @default(now())
  treatmentDone  String
  toothNumber    String?
  cost           Float    @default(0)
  paid           Float    @default(0)
  due            Float    @default(0)
  notes          String?
  doctorSignature String?
  createdAt      DateTime @default(now())

  @@index([patientId])
}

// ============== APPOINTMENTS ==============

model Appointment {
  id            String   @id @default(cuid())
  patientId     String
  patient       Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  userId        String
  user          User     @relation(fields: [userId], references: [id])

  clinicId      String
  clinic        Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  /// Optional operatory/chair id for future chair scheduling (nullable).
  chairId       String?

  date          DateTime
  time          String
  duration      Int      @default(30)
  type          String?
  status        String   @default("SCHEDULED")
  notes         String?
  reminderSent  Boolean  @default(false)
  reminderSentAt DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([id, clinicId], name: "appointment_id_clinic_unique")
  @@index([patientId])
  @@index([userId])
  @@index([date])
  @@index([clinicId])
  @@index([clinicId, userId, date])
  @@index([clinicId, chairId, date])
}

/// Simple queue when no slot is available — staff-managed waitlist (Scheduling domain).
model AppointmentWaitlistEntry {
  id            String    @id @default(cuid())
  clinicId      String
  clinic        Clinic    @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  patientId     String
  patient       Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  preferredDate DateTime?
  duration      Int       @default(30)
  notes         String?
  createdAt     DateTime  @default(now())

  @@index([clinicId])
  @@index([patientId])
}

// ============== PRESCRIPTIONS ==============

model Prescription {
  id            String   @id @default(cuid())
  patientId     String
  patient       Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  
  date          DateTime @default(now())
  diagnosis     String?
  chiefComplaint String?
  examination   String?
  investigation String?
  advice        String?
  followUpDate  DateTime?
  
  vitals        String?
  items         PrescriptionItem[]
  
  pdfUrl        String?
  sentViaWhatsapp Boolean @default(false)
  sentViaEmail  Boolean  @default(false)
  sentViaSms    Boolean  @default(false)
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([patientId])
  @@index([userId])
}

model PrescriptionItem {
  id              String   @id @default(cuid())
  prescriptionId  String
  prescription    Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)
  
  drugName        String
  genericName     String?
  dosage          String
  frequency       String
  duration        String
  maxDailyDose    String?
  doctorNotes     String?
  allowDoseOverride Boolean @default(false)
  beforeFood      Boolean  @default(false)
  afterFood       Boolean  @default(true)
  instructions    String?

  @@index([prescriptionId])
}

// ============== BILLING & INVOICES ==============

model Invoice {
  id            String   @id @default(cuid())
  invoiceNo     String   @unique
  patientId     String
  patient       Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  userId        String
  user          User     @relation(fields: [userId], references: [id])

  clinicId      String
  clinic        Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  date          DateTime @default(now())
  dueDate       DateTime?
  
  subtotal      Float    @default(0)
  discount      Float    @default(0)
  tax           Float    @default(0)
  total         Float    @default(0)
  paid          Float    @default(0)
  due           Float    @default(0)
  
  status        String   @default("PENDING")
  notes         String?
  
  pdfUrl        String?
  sentViaWhatsapp Boolean @default(false)
  sentViaEmail  Boolean  @default(false)
  
  items         InvoiceItem[]
  payments      Payment[]
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([id, clinicId], name: "invoice_id_clinic_unique")
  @@index([patientId])
  @@index([userId])
  @@index([clinicId])
}

model InvoiceItem {
  id          String   @id @default(cuid())
  invoiceId   String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  
  description String
  quantity    Int      @default(1)
  unitPrice   Float    @default(0)
  total       Float    @default(0)
  
  @@index([invoiceId])
}

model Payment {
  id          String   @id @default(cuid())
  invoiceId   String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  amount      Float    @default(0)
  method      String   @default("CASH")
  reference   String?
  date        DateTime @default(now())
  notes       String?

  /// CASH | BKASH | NAGAD | STRIPE (server-normalized; never trust client-paid flags).
  paymentSource         String    @default("CASH")
  /// RECORDED | RECONCILED (cash drawer) | VERIFIED | REJECTED (legacy mirror of paymentStatus where applicable)
  reconciliationStatus  String    @default("RECORDED")
  /// PENDING = awaiting verification (MFS / async Stripe). VERIFIED = included in invoice balances. REJECTED = not counted.
  paymentStatus         String    @default("PENDING")
  transactionRef        String?
  verifiedByUserId      String?
  verifiedByUser        User?     @relation("InvoicePaymentVerifiedBy", fields: [verifiedByUserId], references: [id], onDelete: SetNull)
  stripePaymentIntentId String?  @unique
  verifiedAt            DateTime?

  @@index([invoiceId])
}

// ============== LAB TRACKING ==============

model LabOrder {
  id            String   @id @default(cuid())
  patientId     String
  patient       Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  
  labName       String?
  orderDate     DateTime @default(now())
  expectedDate  DateTime?
  deliveryDate  DateTime?
  
  workType      String
  description   String
  toothNumber   String?
  shade         String?
  
  status        String   @default("PENDING")
  cost          Float?
  notes         String?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([patientId])
  @@index([userId])
}

// ============== DENTAL SHOP (E-COMMERCE) ==============

/// Public dental shop catalog (table `Product`). Prisma name avoids clashing with tenant `Product`.
model ShopProduct {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique
  description   String?
  shortDesc     String?
  price         Float    @default(0)
  comparePrice  Float?
  cost          Float?
  sku           String?
  barcode       String?
  
  category      String
  images        String?
  
  stock         Int      @default(0)
  lowStockAlert Int      @default(5)
  trackInventory Boolean @default(true)
  
  isActive      Boolean  @default(true)
  isFeatured    Boolean  @default(false)
  
  weight        Float?
  dimensions    String?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  orderItems    ShopOrderItem[]
  cartItems     CartItem[]

  @@index([category])
  @@index([isActive])
  @@map("Product")
}

model Cart {
  id            String   @id @default(cuid())
  sessionId     String   @unique
  items         CartItem[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model CartItem {
  id            String   @id @default(cuid())
  cartId        String
  cart          Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId     String
  product       ShopProduct @relation(fields: [productId], references: [id])
  quantity      Int      @default(1)
  
  @@unique([cartId, productId])
  @@index([cartId])
}

/// Public shop checkout order (table `Order`).
model ShopOrder {
  id              String   @id @default(cuid())
  orderNo         String   @unique
  
  customerName    String
  customerEmail   String?
  customerPhone   String
  
  shippingAddress String
  shippingCity    String
  shippingState   String?
  shippingZip     String?
  shippingCountry String   @default("Bangladesh")
  
  subtotal        Float    @default(0)
  shipping        Float    @default(0)
  discount        Float    @default(0)
  total           Float    @default(0)
  
  status          String   @default("PENDING")
  paymentMethod   String   @default("COD")
  paymentStatus   String   @default("PENDING")
  
  notes           String?
  trackingNumber  String?
  
  items           ShopOrderItem[]
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([customerPhone])
  @@index([status])
  @@map("Order")
}

model ShopOrderItem {
  id          String   @id @default(cuid())
  orderId     String
  order       ShopOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String
  product     ShopProduct @relation(fields: [productId], references: [id])
  
  name        String
  price       Float    @default(0)
  quantity    Int
  total       Float    @default(0)

  @@index([orderId])
  @@map("OrderItem")
}

// ============== COMMUNICATION LOGS ==============

model SmsLog {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  
  phone       String
  message     String
  type        String
  status      String
  twilioSid   String?
  error       String?
  sentAt      DateTime @default(now())

  @@index([userId])
}

model EmailLog {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  
  to          String
  subject     String
  body        String?
  type        String
  status      String
  error       String?
  sentAt      DateTime @default(now())

  @@index([userId])
}

// ============== PATIENT CONSENT ==============

model PatientConsent {
  id            String   @id @default(cuid())
  patientId     String
  patient       Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  
  consentType   String
  consentText   String
  signatureName String
  signatureDate DateTime
  agreed        Boolean  @default(false)
  
  createdAt     DateTime @default(now())

  @@index([patientId])
}

// ============== ACTIVITY LOG (for role-based access & super admin) ==============

model ActivityLog {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  clinicId   String?
  clinic     Clinic?  @relation("ClinicActivityLogs", fields: [clinicId], references: [id], onDelete: SetNull)
  action     String   // e.g. LOGIN_SUCCESS, USER_CREATED, PRODUCT_UPDATED
  entity     String?  // e.g. PATIENT, PRODUCT, ORDER
  entityId   String?
  details    String?  // legacy text / JSON string
  meta       Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([clinicId])
  @@index([action])
  @@index([entity])
  @@index([createdAt])
}

// ============== DOCTOR / PRACTICE PANEL ==============

/// Optional JSON `header`: `{ "doctorName": string, "doctorLogo": string }` for prescriptions and dashboard.
model DoctorPanelSettings {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  header    Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("doctor_panel_settings")
}

// ============== TENANT SAAS (PROFILE, CATALOG, ORDERS, PROFIT) ==============

model Profile {
  id           String   @id @default(uuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  displayName  String?
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("profiles")
}

/// Per-clinic catalog for SaaS `/api/products` (table `saas_products`). `price` = sell price.
model Product {
  id         String      @id @default(uuid())
  name       String
  price      Float
  costPrice  Float       @default(0)
  imageUrl   String?
  clinicId   String
  clinic     Clinic      @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@index([clinicId])
  @@map("saas_products")
}

/// Tenant order header for `/api/orders` (table `saas_orders`).
model Order {
  id            String        @id @default(uuid())
  clinicId      String
  clinic        Clinic        @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  currency      String        @default("BDT")
  status        String        @default("CONFIRMED")
  subtotal      Float         @default(0)
  total         Float         @default(0)
  paymentStatus String        @default("UNPAID")

  notes         String?

  items         OrderItem[]
  transactions  Transaction[]
  profit        Profit?

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([clinicId])
  @@index([status])
  @@map("saas_orders")
}

/// Line item: one row per product line on a tenant order (table `saas_order_items`).
model OrderItem {
  id          String   @id @default(uuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Restrict)

  quantity    Int
  unitPrice   Float
  lineTotal   Float
  productName String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([orderId])
  @@index([productId])
  @@map("saas_order_items")
}

/// Payment / payout record for a tenant order (table `transactions`).
model Transaction {
  id           String   @id @default(uuid())
  orderId      String
  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  amount       Float
  currency     String   @default("BDT")
  status       String   @default("PENDING")
  provider     String?
  externalRef  String?
  metadata     String?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([orderId])
  @@index([status])
  @@map("transactions")
}

model Profit {
  id        String   @id @default(uuid())
  orderId   String   @unique
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  clinicId  String
  clinic    Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  /// Sum over line items: (sell_price - cost_price) * quantity
  amount    Float
  createdAt DateTime @default(now())

  @@index([clinicId])
  @@map("profits")
}

