# Alpha / staging backend — copy to server/.env on the alpha host (never commit).
# Works with Supabase Postgres + Supabase Auth (optional but recommended for password reset / sync).

NODE_ENV=production

# Exact browser origins that will call this API (CORS). Include https:// and www if used.
# Example: https://baigdentpro.com,https://www.baigdentpro.com
FRONTEND_URL=https://YOUR_ALPHA_DOMAIN

# Supabase → Project Settings → Database → Connection string (URI).
# Use "Session mode" or "Transaction" pooler for many hosts; include ?sslmode=require
# Example shape: postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?sslmode=require
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/postgres?sslmode=require

# openssl rand -base64 48   (must be 32+ chars; not a placeholder word)
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Supabase → Project Settings → API
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# service_role — server only; never expose to the client
SUPABASE_SERVICE_ROLE_KEY=

PORT=3001

# Optional: stricter rate limits (see server/.env.example)
# AUTH_RATE_LIMIT_MAX=40
# API_RATE_LIMIT_MAX=200

# Optional: first seed / service account (see server/src/seed.ts)
# OMIX_SERVICE_USER_EMAIL=
# OMIX_SERVICE_USER_PASSWORD=

# Optional integrations (leave unset for alpha if unused)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
